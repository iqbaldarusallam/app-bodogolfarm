# ─────────────────────────────────────────────────────────
# Bodogol Farm Livestock API — Environment Variables
# Copy this to .env and fill in production values
# ─────────────────────────────────────────────────────────

# Server
NODE_ENV=production
PORT=3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/bodogol

# JWT — REQUIRED in production (app won't start without these)
JWT_SECRET=<generate-a-strong-random-secret>
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=<generate-another-strong-random-secret>
JWT_REFRESH_EXPIRES_IN=30d

# CORS — REQUIRED in production (explicit origin, not *)
CORS_ORIGIN=https://your-app-domain.com
